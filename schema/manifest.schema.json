{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/kvlsx/vertex-extensions/main/schema/manifest.schema.json",
  "title": "Vertex Extension Manifest",
  "description": "A Vertex extension is data-only (no executable code). Currently a 'service-pack' that adds services to the hub.",
  "type": "object",
  "required": ["id", "name", "version", "type"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "type": { "type": "string", "enum": ["service-pack"] },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "url"],
        "properties": {
          "type": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "url": { "type": "string", "pattern": "^https?://" },
          "icon": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{3,8}$" }
        }
      }
    }
  }
}
